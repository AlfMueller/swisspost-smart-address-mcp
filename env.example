# Swisspost API Credentials
# Diese Werte müssen von der Swisspost API bezogen werden
# Kopieren Sie diese Datei zu .env und ersetzen Sie die Platzhalter durch Ihre echten Credentials
SWISSPOST_CLIENT_ID=your_actual_client_id_here
SWISSPOST_CLIENT_SECRET=your_actual_client_secret_here

# Optional: Scope für die API (Standard: DCAPI_ADDRESS_VALIDATE)
SWISSPOST_SCOPE=DCAPI_ADDRESS_VALIDATE
